# Browser-safe Vite values
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
VITE_SUPABASE_ANON_KEY=YOUR_LEGACY_ANON_KEY_IF_NEEDED

# Set to true on Vercel after the API env vars below are configured.
# Keep false for offline/local UI testing.
VITE_USE_SERVER_AUTH=false

# Server-only values for Vercel API routes. Do not expose these in the browser.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY
RESEND_API_KEY=YOUR_RESEND_API_KEY
RESEND_FROM_EMAIL=onboarding@resend.dev
PASSWORD_CHANGE_EMAIL=mahmoud_foly@icloud.com
OTP_PEPPER=replace-with-a-long-random-secret
OTP_DEV_MODE=false
