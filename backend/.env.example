NODE_ENV=development
PORT=4000
APP_ORIGIN=http://127.0.0.1:5173
# Production/Vercel: use the Supabase PostgreSQL connection string from Project Settings > Database.
# Local Docker may override this with postgres://zunion:zunion@db:5432/zunion in docker-compose.yml.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DATABASE_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres
DATABASE_SSL=true
COOKIE_SECRET=change-this-long-random-secret
SESSION_COOKIE_NAME=zunion_session
UPLOAD_DIR=/app/uploads
OTP_DEV_MODE=true
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM="Zunion <onboarding@resend.dev>"
PASSWORD_CHANGE_EMAIL=mahmoud_foly@icloud.com
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Zunion <no-reply@zunion.local>"
